# Core
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hub_studio

# Infra
REDIS_URL=redis://localhost:6379
UPLOAD_STORAGE_DIR=app/public/uploads
UPLOAD_MAX_IMAGE_SIZE_MB=25
UPLOAD_MAX_VIDEO_SIZE_MB=500
UPLOAD_MAX_PDF_SIZE_MB=100
UPLOAD_MAX_FILE_SIZE_MB=100

# Observability (optional)
LOG_LEVEL=info
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
